# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/cyber7

# JWT secret for auth tokens (required – use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server port (optional, default 3001)
BACKEND_PORT=3001

# ConnectWise API – same as frontend, used by backend to fetch alerts
CW_BASE_URL=https://api-na.myconnectwise.net/v4_6_release/apis/3.0
CW_COMPANY_ID=your_company_id
CW_PUBLIC_KEY=your_public_key
CW_PRIVATE_KEY=your_private_key
CW_CLIENT_ID=your_client_id
